# Database
DATABASE_URL="file:./dev.db"

# Auth — generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Demo gate (закрытый предпросмотр сайта). Установите DEMO_GATE_ENABLED=false, чтобы выключить.
DEMO_GATE_ENABLED="true"
DEMO_USER="admin2222"
DEMO_PASS="karim22333"
# Optional separate secret for the demo cookie. Falls back to JWT_SECRET.
DEMO_SECRET=""

# Public site URL (used for absolute links, sitemap, OG)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Yandex.Metrika counter ID (optional, leave empty to disable)
NEXT_PUBLIC_YANDEX_METRIKA_ID=""

# Yandex Maps embed URL (optional, used on /contacts)
NEXT_PUBLIC_YANDEX_MAP_EMBED=""

# ==================== Marketing-MVP integrations ============================
# Yandex Maps JS API key (для интерактивной карты на /coverage)
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""

# Yandex SmartCaptcha (для анти-спама форм)
# Sitekey виден на клиенте, server key — секретный.
NEXT_PUBLIC_SMARTCAPTCHA_SITE_KEY=""
SMARTCAPTCHA_SERVER_KEY=""

# Bitrix24 inbound webhook URL (https://<домен>.bitrix24.ru/rest/<user>/<token>/)
# Лиды пушатся через crm.lead.add. Если не задан — лиды только в БД и админке.
BITRIX24_WEBHOOK_URL=""

# Unisender — транзакционные уведомления админу о новой заявке
UNISENDER_API_KEY=""
UNISENDER_LIST_ID="1"
UNISENDER_FROM_EMAIL="noreply@rutega.ru"
ADMIN_ALERT_EMAIL=""

# Node env
NODE_ENV="development"
